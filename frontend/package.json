{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "tsc -b config/tsconfig.json && vite build --config config/vite.config.ts",
    "lint": "eslint --config config/eslint.config.js .",
    "preview": "vite preview --config config/vite.config.ts",
    "test:e2e": "playwright test --config config/playwright.config.ts",
    "test:e2e:ui": "playwright test --config config/playwright.config.ts --ui"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.15.2",
    "@tanstack/react-query": "^5.99.0",
    "aws-amplify": "^6.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "@playwright/test": "^1.49.0"
  }
}
